{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "AssociateRouteTable",
  "group": "route-table",
  "title": "将路由表和交换机绑定",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "update",
  "description": "**AssociateRouteTable**接口属于异步接口，即系统返回一个请求ID，但该路由表并未绑定完成，系统后台的绑定任务仍在进行。您可以调用DescribeVSwitchAttributes查询路由表的绑定状态：\n- 当交换机处于**Pending**状态时，表示路由表正在绑定中。\n- 当交换机处于**Available**状态时，表示路由表绑定成功。",
  "requestParamsDescription": "",
  "responseParamsDescription": "",
  "extraInfo": "",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "要绑定交换机的路由表所属的VPC的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-hangzhou"
      }
    },
    {
      "name": "RouteTableId",
      "in": "query",
      "schema": {
        "description": "要绑定到交换机的路由表的ID。",
        "type": "string",
        "required": true,
        "example": "vtb-bp145q7glnuzdvzu2****"
      }
    },
    {
      "name": "VSwitchId",
      "in": "query",
      "schema": {
        "description": "要绑定路由表的交换机的ID。",
        "type": "string",
        "required": true,
        "example": "vsw-25ncdvfaue4****"
      }
    },
    {
      "name": "ClientToken",
      "in": "query",
      "schema": {
        "description": "客户端Token，用于保证请求的幂等性。\n\n从您的客户端生成一个参数值，确保不同请求间该参数值唯一。ClientToken只支持ASCII字符。\n\n> 若您未指定，则系统自动使用API请求的**RequestId**作为**ClientToken**标识。每次API请求的**RequestId**可能不一样。",
        "type": "string",
        "required": false,
        "example": "02fb3da4-130e-11e9-8e44-0016e04115b"
      }
    },
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "要绑定交换机的路由表所属的VPC的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-hangzhou"
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "type": "object",
        "properties": {
          "RequestId": {
            "description": "请求ID。",
            "type": "string",
            "example": "DC668356-BCB4-42FD-9BC3-FA2B2E04B634"
          }
        },
        "description": ""
      }
    }
  },
  "errorCodes": {
    "400": [
      {
        "errorCode": "OperationDenied.CloudBoxVbrEntryExist",
        "errorMessage": "The operation is not allowed because the routing table has a route entry for the next hop to the cloud box VBR.",
        "description": "指定操作不允许，因为路由表存在下一跳指向云盒VBR的路由条目。"
      },
      {
        "errorCode": "OperationDenied.OtherCloudBoxVbrEntryExist",
        "errorMessage": "The operation is not allowed because the routing table has a route entry for the next hop that points to a VBR other than this cloud box.",
        "description": "指定操作不允许，因为路由表存在下一跳指向非本云盒VBR的路由条目。"
      },
      {
        "errorCode": "ResourceAlreadyAssociated.RouteTable",
        "errorMessage": "The resource has already associated with a routetable.",
        "description": ""
      },
      {
        "errorCode": "OperationDenied.AssociateGatewayRouteTable",
        "errorMessage": "The operation is not allowed because gateway route tables cannot be bound to a vSwitch.",
        "description": "交换机不允许绑定网关路由表。"
      },
      {
        "errorCode": "OperationDenied.SwitchToSystemRouteTable",
        "errorMessage": "The associated route tables cannot be directly changed to system route tables.",
        "description": "无法将绑定路由表直接切换为系统路由表。"
      },
      {
        "errorCode": "ResourceNotFound.VSwitch",
        "errorMessage": "The specified resource of VSwitch is not found.",
        "description": "指定的VSwitch实例不存在"
      },
      {
        "errorCode": "InvalidRouteTableId.NotFound",
        "errorMessage": "Specified route table does not exist.",
        "description": ""
      },
      {
        "errorCode": "OperationDenied.LocalRouteEntryModified",
        "errorMessage": "The next hop of a local route is modified.",
        "description": "存在local类型的路由下一跳被修改了。"
      },
      {
        "errorCode": "MissingParam.VSwitchId",
        "errorMessage": "The parameter VSwitchId is missing.",
        "description": "参数VSwitchId缺失"
      },
      {
        "errorCode": "InvalidRegionId.NotFound",
        "errorMessage": "Specified value of RegionId is not supported.",
        "description": ""
      },
      {
        "errorCode": "InvalidParameter.Action",
        "errorMessage": "This vpc feature is not supported in this region",
        "description": ""
      },
      {
        "errorCode": "IncorrectVSwitchStatus",
        "errorMessage": "The current status of the virtual switch does not support this operation.",
        "description": ""
      },
      {
        "errorCode": "Forbidden.VSwitchAlreadyAssociatedRouteTable",
        "errorMessage": "The specified virtual switch already associates route table.",
        "description": ""
      },
      {
        "errorCode": "Forbidden.NotInSameVpc",
        "errorMessage": "The specified virtual switch and route table are not in the same VPC.",
        "description": ""
      },
      {
        "errorCode": "IncorrectStatus.RouteTable",
        "errorMessage": "The status of the specified route table is incorrect.",
        "description": ""
      }
    ],
    "404": [
      {
        "errorCode": "InvalidRouteTableId.NotFound",
        "errorMessage": "Specified route table does not exist.",
        "description": ""
      },
      {
        "errorCode": "InvalidVSwitchId.NotFound",
        "errorMessage": "Specified VSwitch does not exist.",
        "description": ""
      }
    ]
  },
  "responseDemo": [
    {
      "type": "json",
      "example": "{\n  \"RequestId\": \"DC668356-BCB4-42FD-9BC3-FA2B2E04B634\"\n}",
      "errorExample": ""
    },
    {
      "type": "xml",
      "example": "<AssociateRouteTableResponse>\r\n<RequestId>DC668356-BCB4-42FD-9BC3-FA2B2E04B634</RequestId>\r\n</AssociateRouteTableResponse>",
      "errorExample": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<AssociateRouteTableResponse>\n    <RequestId>62172DD5-6BAC-45DF-8D44-xxxxxxx</RequestId>\n</AssociateRouteTableResponse>"
    }
  ]
}