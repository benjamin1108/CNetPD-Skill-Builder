  "errorCodes": {
    "400": [
      {
        "errorCode": "IllegalParam.NextToken",
        "errorMessage": "The specified NextToken is invalid.",
        "description": "参数NextToken非法."
      }
    ],
    "404": [
      {
        "errorCode": "ResourceNotFound.CidrReservation",
