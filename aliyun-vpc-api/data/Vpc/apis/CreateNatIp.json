{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "CreateNatIp",
  "group": "nat",
  "title": "创建NAT IP地址",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "create",
  "description": "**CreateNatIp**接口属于异步接口，即系统会先返回一个NAT IP地址，但该NAT IP地址并未创建完成，系统后台的创建任务仍在进行。您可以调用ListNatIps查询NAT IP地址创建的状态：\n\n- 当NAT IP地址处于**Creating**状态时，表示NAT IP地址正在创建中，在该状态下，您只能执行查询操作，不能执行其他操作。\n\n- 当NAT IP地址处于**Available**状态时，表示NAT IP地址创建完成。\n\n**CreateNatIp**接口在同一个NAT网关内不支持并发创建NAT IP地址。",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "要创建NAT IP地址所属NAT网关实例的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "eu-central-1"
      }
    },
    {
      "name": "NatGatewayId",
      "in": "query",
      "schema": {
        "description": "NAT IP地址所属的VPC NAT网关实例ID。",
        "type": "string",
        "required": true,
        "example": "ngw-gw8v16wgvtq26vh59****"
      }
    },
    {
      "name": "NatIpName",
      "in": "query",
      "schema": {
        "description": "创建的NAT IP地址的名称。\n\n长度为2~128个字符，必须以字母或中文开头，可包含数字、半角句号（.）、下划线（_）和短划线（-）。但不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "newnatip"
      }
    },
    {
      "name": "NatIpDescription",
      "in": "query",
      "schema": {
        "description": "创建的NAT IP地址的描述信息。\n\n长度为2~256个字符，必须以字母或中文开头，但不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "test"
      }
    },
    {
      "name": "DryRun",
      "in": "query",
      "schema": {
        "description": "是否只预检此次请求，取值：\n\n- **true**：发送检查请求，不会创建NAT IP地址。检查项包括AccessKey是否有效、RAM用户的授权情况和是否填写了必需参数。如果检查不通过，则返回对应错误。如果检查通过，会返回错误码`DryRunOperation`。\n\n- **false**（默认值）：发送正常请求，通过检查后返回2xx HTTP状态码并创建NAT IP地址。",
        "type": "boolean",
        "required": false,
        "example": "false"
      }
    },
    {
      "name": "ClientToken",
      "in": "query",
      "schema": {
        "description": "客户端Token，用于保证请求的幂等性。\n\n从您的客户端生成一个参数值，确保不同请求间该参数值唯一。ClientToken只支持ASCII字符。\n\n> 若您未指定，则系统自动使用API请求的**RequestId**作为**ClientToken**标识。每次API请求的**RequestId**不一样。",
        "type": "string",
        "required": false,
        "example": "5A2CFF0E-5718-45B5-9D4D-70B3FF3898"
      }
    },
    {
      "name": "NatIpCidr",
      "in": "query",
      "schema": {
        "description": "创建NAT IP地址的地址段。",
        "type": "string",
        "required": true,
        "example": "192.168.0.0/24"
      }
    },
    {
      "name": "NatIp",
      "in": "query",
      "schema": {
        "description": "创建的NAT IP地址。\n\n如果您不指定该IP地址，系统会在您的NAT IP地址段中随机分配一个IP地址。",
        "type": "string",
        "required": false,
        "example": "192.168.0.34"
      }
    },
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "要创建NAT IP地址所属NAT网关实例的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "eu-central-1"
      }
    },
    {
      "name": "Ipv4Prefix",
      "in": "query",
      "schema": {
        "description": "创建的IP前缀地址段。\n\n该IP前缀地址段必须位于NAT所在交换机的预留网段内，且预留网段不能被占用。IP前缀掩码必须为/28。",
        "type": "string",
        "required": false,
        "example": "192.168.0.0/28"
      }
    },
    {
      "name": "Ipv4PrefixCount",
      "in": "query",
      "schema": {
        "description": "自动分配的IP前缀数量。\n\n从NAT所在交换机的未分配预留网段内随机分配。取值范围：1~10。",
        "type": "integer",
        "format": "int32",
        "required": false,
        "example": "1"
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "description": "创建的NAT IP地址。",
        "type": "object",
        "properties": {
          "NatIp": {
            "description": "创建的NAT IP地址。",
            "type": "string",
            "example": "192.168.0.34"
          },
          "RequestId": {
            "description": "请求ID。",
            "type": "string",
            "example": "E9AD97A0-5338-43F8-8A80-5E274CCBA11B"
          },
          "NatIpId": {
            "description": "创建的NAT IP地址实例ID。",
            "type": "string",
            "example": "vpcnatip-gw8y7q3cpk3fggs8****"
          },
          "Ipv4Prefix": {
            "description": "旧接口返回的Ipv4Prefix，已经废弃。",
            "type": "string",
            "example": "\"\""
          },
          "NatIps": {
            "description": "创建NatIp后返回的NatIp参数，当使用IPv4Prefix创建NatIp后将返回所有的NatIp信息，当创建单个NatIp时也推荐使用此参数获取NatIp信息。",
            "type": "array",
            "items": {
              "description": "创建的Ipv4Preix时返回创建的NatIpList列表。",
              "type": "object",
              "properties": {
                "NatIp": {
                  "description": "创建的Ipv4Preix时返回创建的NatIpList列表的NatIp地址。",
                  "type": "string",
                  "example": "192.168.2.128"
                },
                "NatIpId": {
                  "description": "创建的Ipv4Preix时返回创建的NatIpList列表的NatIpId。",
                  "type": "string",
                  "example": "vpcnatip-xxxxxxxx"
                },
                "Ipv4Prefix": {
                  "description": "创建的Ipv4Preix时返回创建的NatIpList列表的Ipv4Prefix。",
                  "type": "string",
                  "example": "192.168.1.128/28"
                }
              }
            }
          }
        }
      }
    }
  },
  "errorCodes": {
    "400": [
      {
        "errorCode": "Mismatch.NatIpAndNatIpCidr",
        "errorMessage": "The %s and %s are mismatched.",
        "description": "%s和%s不匹配。"
      },
      {
        "errorCode": "ResourceNotFound.NatGateway",
        "errorMessage": "The specified resource of %s is not found.",
        "description": ""
      },
      {
        "errorCode": "ResourceNotFound.NatIpCidr",
        "errorMessage": "The specified resource of %s is not found.",
        "description": "找不到指定的%s资源。"
      },
      {
        "errorCode": "IncorrectStatus.NatGateway",
        "errorMessage": "%The status of %s [%s] is incorrect.",
        "description": "nat网关状态不正确"
      },
      {
        "errorCode": "QuotaExceeded.NatIp",
        "errorMessage": "The quota of %s is exceeded, usage %s/%s.",
        "description": "NatIp和Ipv4Prefix配额使用溢出。"
      },
      {
        "errorCode": "ResourceNotEnough.SwitchAvailableIps",
        "errorMessage": "The available private Ip number is not enough in your subnet.",
        "description": "子网中可用的私网IP不足。"
      },
      {
        "errorCode": "ResourceNotEnough.NatIp",
        "errorMessage": "The specified resource of NatIp is not enough.",
        "description": "Insufficient IP addresses in the specified CIDR block."
      },
      {
        "errorCode": "ResourceAlreadyExist.NatIp",
        "errorMessage": "The specified resource of NatIp has already exist.",
        "description": "配置的NatIp已存在"
      },
      {
        "errorCode": "Mismatch.Ipv4PrefixAndNatIpCidr",
        "errorMessage": "The %s and %s are mismatched.",
        "description": ""
      },
      {
        "errorCode": "Mismatch.Ipv4PrefixAndCidrReservations",
        "errorMessage": "The %s and %s are mismatched.",
        "description": "Ipv4Prefix和交换机预留网段不匹配。"
      },
      {
        "errorCode": "ResourceAlreadyAssociated.Ipv4Prefix",
        "errorMessage": "%s is already associated.",
        "description": "Ipv4Prefix已经被分配。"
      },
      {
        "errorCode": "ResourceNotEnough.Ipv4Prefix",
        "errorMessage": "The resource of %s is not enough.",
        "description": "Ipv4Prefix资源不足。"
      },
      {
        "errorCode": "ResourceNotFound.Ipv4Prefix",
        "errorMessage": "The resource of s% is not found.",
        "description": "资源Ipv4Prefix不存在。"
      },
      {
        "errorCode": "ResourceAlreadyAssociated.NatIp",
        "errorMessage": "The resource of %s was already associated.",
        "description": "NatIp资源已经被分配。"
      },
      {
        "errorCode": "ResourceNotFound.NatIp",
        "errorMessage": "The specified resource of %s is not found.",
        "description": "NatIp资源找不到。"
      },
      {
        "errorCode": "IllegalParam.Ipv4Prefix",
        "errorMessage": "The param of %s is illegal, must be /28 network segment.",
        "description": "参数Ipv4Prefix不合法，必须为/28网段"
      },
      {
        "errorCode": "ResourceAlreadyExist.Ipv4Prefix",
        "errorMessage": "The specified resource of %s is already exist.",
        "description": "已经创建过该Ipv4Prefix,请勿重新创建。"
      },
      {
        "errorCode": "QuotaExceeded.Ipv4Prefix",
        "errorMessage": "The quota of %s is exceeded, usage %s/%s.",
        "description": "Ipv4Prefix的配额使用溢出。"
      },
      {
        "errorCode": "OperationFailed.InstanceNotSupport",
        "errorMessage": "natgateway not support ipv4prefix.",
        "description": "网关不支持Ipv4Prefix。"
      }
    ],
    "404": [
      {
        "errorCode": "InvalidRegionId.NotFound",
        "errorMessage": "The specified RegionId does not exist in our records.",
        "description": ""
      }
    ]
  },
  "responseDemo": [
    {
      "type": "json",
      "example": "{\n  \"NatIp\": \"192.168.0.34\",\n  \"RequestId\": \"E9AD97A0-5338-43F8-8A80-5E274CCBA11B\",\n  \"NatIpId\": \"vpcnatip-gw8y7q3cpk3fggs8****\",\n  \"Ipv4Prefix\": \"\\\"\\\"\",\n  \"NatIps\": [\n    {\n      \"NatIp\": \"192.168.2.128\",\n      \"NatIpId\": \"vpcnatip-xxxxxxxx\",\n      \"Ipv4Prefix\": \"192.168.1.128/28\"\n    }\n  ]\n}",
      "errorExample": ""
    },
    {
      "type": "xml",
      "example": "<CreateNatIpResponse>\n    <NatIp>192.168.0.34</NatIp>\n    <RequestId>E9AD97A0-5338-43F8-8A80-5E274CCBA11B</RequestId>\n    <NatIpId>vpcnatip-gw8y7q3cpk3fggs8****</NatIpId>\n</CreateNatIpResponse>",
      "errorExample": ""
    }
  ]
}