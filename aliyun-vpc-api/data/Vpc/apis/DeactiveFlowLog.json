{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "DeactiveFlowLog",
  "group": "flow-log",
  "title": "停止流日志",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "update",
  "description": "- **DeactiveFlowLog**接口属于异步接口，即系统返回一个请求ID，但该流日志尚未停止，系统后台的停止任务仍在进行。您可以调用DescribeFlowLogs查询流日志的停止状态：\n    - 当流日志处于**Deactivating**状态时，表示流日志正在停止中。\n    - 当流日志处于**Inactive**状态时，表示流日志停止完成。\n- **DeactiveFlowLog**接口不支持并发停止同一个流日志。",
  "requestParamsDescription": "",
  "responseParamsDescription": "",
  "extraInfo": "",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "流日志所属的地域ID。您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-qingdao"
      }
    },
    {
      "name": "FlowLogId",
      "in": "query",
      "schema": {
        "description": "流日志ID。",
        "type": "string",
        "required": true,
        "example": "fl-m5e8vhz2t21sel1nq****"
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "type": "object",
        "properties": {
          "Success": {
            "description": "是否调用成功。\n\n- **true**：调用成功。\n- **false**：调用失败。",
            "type": "string",
            "example": "true"
          },
          "RequestId": {
            "description": "请求ID。",
            "type": "string",
            "example": "F7DDDC17-FA06-4AC2-8F35-59D2470FCFC1"
          }
        }
      }
    }
  },
  "errorCodes": {
    "400": [
      {
        "errorCode": "IncorrectBusinessStatus.FlowLog",
        "errorMessage": "The business status of flowLog  is incorrect.",
        "description": "当前业务状态不支持创建流日志实例"
      },
      {
        "errorCode": "InvalidInstanceId",
        "errorMessage": "Instance does not exist.",
        "description": "实例不存在。"
      },
      {
        "errorCode": "InvalidStatus",
        "errorMessage": "Current instance status is not valid for this action.",
        "description": ""
      },
      {
        "errorCode": "FlowLogNumberOverLimit",
        "errorMessage": "This user has reached the maximum instance number of flowlog.",
        "description": ""
      },
      {
        "errorCode": "InvalidRegionId.NotFound",
        "errorMessage": "The RegionId provided does not exist in our records.",
        "description": ""
      },
      {
        "errorCode": "InvalidInstanceId.NotFound",
        "errorMessage": "The specfied instance is not existed.",
        "description": ""
      },
      {
        "errorCode": "IncorrectStatus.flowlog",
        "errorMessage": "Invalid flowlog status.",
        "description": "flowlog状态无效，无法停止"
      },
      {
        "errorCode": "Forbidden.OperateManagedFlowLog",
        "errorMessage": "Authentication is failed for operate managed flowlog.",
        "description": "操作托管的流日志，鉴权失败。"
      }
    ]
  },
  "responseDemo": [
    {
      "type": "json",
      "example": "{\n  \"Success\": \"true\",\n  \"RequestId\": \"F7DDDC17-FA06-4AC2-8F35-59D2470FCFC1\"\n}",
      "errorExample": ""
    },
    {
      "type": "xml",
      "example": "<DeactiveFlowLogResponse>\n    <Success>true</Success>\n    <RequestId>F7DDDC17-FA06-4AC2-8F35-59D2470FCFC1</RequestId>\n</DeactiveFlowLogResponse>",
      "errorExample": ""
    }
  ]
}