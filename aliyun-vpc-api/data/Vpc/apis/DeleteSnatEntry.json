        "errorMessage": "Specified Snat entry ID does not exist",
        "description": ""
      },
      {
        "errorCode": "InvalidSnatTableId.NotFound",
        "errorMessage": "Specified SNAT table does not exist.",
        "description": ""
      },
      {
        "errorCode": "ResourceNotFound.SnatEntry",
