      },
      {
        "errorCode": "EcQoSConflict",
        "errorMessage": "The specified QoS is conflict with other QoS.",
        "description": "当前Qos配置与其他配置冲突，请稍后再试。"
      },
      {
        "errorCode": "QuotaExceeded.QosMediumPriorityQueueBandwidthPercent",
