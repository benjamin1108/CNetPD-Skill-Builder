        "errorMessage": "The specified resource of traffic mirror rule is not found.",
        "description": "指定的流量镜像筛选规则不存在。"
      },
      {
        "errorCode": "IncorrectStatus.TrafficMirrorRule",
        "errorMessage": "The status of traffic mirror rule is incorrect.",
        "description": "流量镜像筛选规则的状态不正确。"
      },
      {
        "errorCode": "DuplicatedParam.Priority",
        "errorMessage": "The specified priority conflicts with the existing priority.",
        "description": "指定的优先级参数与已有的优先级重复。"
      },
      {
        "errorCode": "IllegalParam.Protocol",
        "errorMessage": "The specified Protocol is invalid.",
        "description": "协议参数不合法。"
      },
      {
        "errorCode": "IllegalParam.SourceCidrBlock",
        "errorMessage": "The param of SourceCidrBlock is illegal.",
        "description": "参数SourceCidrBlock非法。"
      },
      {
        "errorCode": "IllegalParam.DestinationCidrBlock",
        "errorMessage": "The param of DestinationCidrBlock is illegal.",
        "description": "参数DestinationCidrBlock非法。"
      }
    ]
  },
  "responseDemo": [
