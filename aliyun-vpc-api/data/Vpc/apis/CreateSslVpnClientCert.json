  "operationType": "create",
  "description": "创建SSL-VPN客户端证书前，请确保VPN网关实例下已经创建了SSL-VPN服务端。具体操作，请参见CreateSslVpnServer。",
  "requestParamsDescription": "",
  "responseParamsDescription": "",
  "extraInfo": "",
  "parameters": [
    {
      "name": "ClientToken",
      "in": "query",
      "schema": {
        "description": "客户端Token，用于保证请求的幂等性。\n\n由客户端生成该参数值，要保证在不同请求间唯一，最大值不超过64个ASCII字符。\n\n> 若您未指定，则系统自动使用API请求的**RequestId**作为**ClientToken**标识。每次API请求的**RequestId**不一样。",
        "type": "string",
        "required": false,
        "example": "02fb3da4-130e-11e9-8e44-0016e04115b"
      }
    },
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "VPN网关所在的地域ID。 \n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-hangzhou"
      }
    },
    {
      "name": "SslVpnServerId",
      "in": "query",
      "schema": {
        "description": "SSL-VPN服务端的ID。",
        "type": "string",
        "required": true,
        "example": "vss-m5et0q3iy1qex328w****"
      }
    },
    {
      "name": "Name",
      "in": "query",
      "schema": {
        "description": "客户端证书的名称。\n\n长度为1～100个字符，不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "SslVpnClientCert1"
      }
    }
  ],
  "responses": {
