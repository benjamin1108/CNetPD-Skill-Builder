          "Name": {
            "description": "SSL-VPN客户端证书的名称。",
            "type": "string",
            "example": "SslVpnClientCert"
          },
          "SslVpnClientCertId": {
            "description": "SSL-VPN客户端证书的ID。",
            "type": "string",
            "example": "vsc-m5euof6s5jy8vs5kd****"
          }
        }
      }
    }
