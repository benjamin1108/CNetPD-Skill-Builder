      "example": "{\n  \"RequestId\": \"62CFC815-E08A-5CF4-92D1-54273EC9E406\",\n  \"EndpointId\": \"vpce-bp1w1dmdqjpwul0v3****\",\n  \"ServiceName\": \"com.aliyun.cn-hangzhou.oss\",\n  \"EndpointName\": \"test\",\n  \"CreationTime\": \"2021-08-27T01:58:37Z\",\n  \"ResourceGroupId\": \"rg-acfmxazb4ph****\"\n}",
