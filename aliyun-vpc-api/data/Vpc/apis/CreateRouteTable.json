{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "CreateRouteTable",
  "group": "route-table",
  "title": "创建自定义路由表",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "create",
  "description": "- **CreateRouteTable**接口属于异步接口，即系统会返回一个实例ID，但该自定义路由表尚未创建完成，系统后台的创建任务仍在进行。您可以调用DescribeRouteTableList查询自定义路由表的创建状态：\n    - 当自定义路由表处于**Creating**状态时，表示自定义路由表创建中。\n    - 当自定义路由表处于**Available**状态时，表示自定义路由表创建完成。\n- **CreateRouteTable**接口不支持在同一个VPC中并发创建自定义路由表。",
  "requestParamsDescription": "",
  "responseParamsDescription": "",
  "extraInfo": "",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "路由表所属的VPC的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-zhangjiakou"
      }
    },
    {
      "name": "VpcId",
      "in": "query",
      "schema": {
        "description": "自定义路由表所属的VPC ID。",
        "type": "string",
        "required": true,
        "example": "vpc-bp1qpo0kug3a20qqe****"
      }
    },
    {
      "name": "RouteTableName",
      "in": "query",
      "schema": {
        "description": "路由表的名称。\n\n名称长度为1～128个字符，不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "myRouteTable"
      }
    },
    {
      "name": "Description",
      "in": "query",
      "schema": {
        "description": "路由表的描述信息。\n\n描述长度为1～256个字符，不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "abc"
      }
    },
    {
      "name": "AssociateType",
      "in": "query",
      "schema": {
        "description": "创建的路由表的类型。取值：\n\n- **VSwitch**（默认值）：交换机路由表。\n- **Gateway**：网关路由表。",
        "type": "string",
        "required": false,
        "example": "VSwitch"
      }
    },
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "路由表所属的VPC的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-zhangjiakou"
      }
    },
    {
      "name": "ClientToken",
      "in": "query",
      "schema": {
        "description": "客户端Token，用于保证请求的幂等性。\n\n从您的客户端生成一个参数值，确保不同请求间该参数值唯一。ClientToken只支持ASCII字符。\n\n> 若您未指定，则系统自动使用API请求的**RequestId**作为**ClientToken**标识。每次API请求的**RequestId**可能不一样。",
        "type": "string",
        "required": false,
        "example": "02fb3da4-130e-11e9-8e44-0016e04"
      }
    },
    {
      "name": "Tag",
      "in": "query",
      "style": "repeatList",
      "schema": {
        "description": "资源的标签。",
        "type": "array",
        "items": {
          "description": "标签。",
          "type": "object",
          "properties": {
            "Key": {
              "description": "资源的标签键。最多支持输入20个标签键。如需传入该值，则不能输入空字符串。\n\n一个标签键最多支持128个字符，不能以`aliyun`和`acs:`开头，不能包含`http://`或者`https://`。",
              "type": "string",
              "required": false,
              "example": "FinanceDept"
            },
            "Value": {
              "description": "资源的标签值。最多支持输入20个标签值。如需传入该值，可以输入空字符串。\n\n最多支持128个字符，不能以`aliyun`和`acs:`开头，不能包含`http://`或者`https://`。",
              "type": "string",
              "required": false,
              "example": "FinanceJoshua"
            }
          },
          "required": false
        },
        "required": false,
        "maxItems": 21
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "description": "路由表的详细信息。",
        "type": "object",
        "properties": {
          "RequestId": {
            "description": "请求ID。",
            "type": "string",
            "example": "62172DD5-6BAC-45DF-8D44-E11ED28DCAC0"
          },
          "RouteTableId": {
            "description": "路由表ID。",
            "type": "string",
            "example": "vtb-bp145q7glnuzdvzu2****"
          }
        }
      }
    }
  },
  "errorCodes": {
    "400": [
      {
        "errorCode": "UnsupportedRegion",
        "errorMessage": "The feature of ipv4Gateway is not supported in the region.",
        "description": "该地域不支持ipv4网关"
      },
      {
        "errorCode": "InvalidParameter.RouteTableName.Malformed",
        "errorMessage": "The specified route table name is not valid.",
        "description": ""
      },
      {
        "errorCode": "InvalidParameter.Description.Malformed",
        "errorMessage": "The specified Description is not valid.",
        "description": ""
      },
      {
        "errorCode": "QuotaExceeded.RouteTable",
        "errorMessage": "VPC RouteTable quota exceeded.",
        "description": "超过VPC RouteTable配额。"
      },
      {
        "errorCode": "IncorrectStatus.cbnStatus",
        "errorMessage": "Current CBN status does not support this operation.",
        "description": "CBN当前状态不正确"
      },
      {
        "errorCode": "InvalidVpcId.NotSupport",
        "errorMessage": "The vpc is not support.",
        "description": ""
      },
      {
        "errorCode": "OperationUnsupported.AdvancedFeature",
        "errorMessage": "Advanced features of the vpc is unsupported.",
        "description": "不支持该高级特性。"
      },
      {
        "errorCode": "QuotaExceeded.GatewayRouteTable",
        "errorMessage": "The quota of Gateway Route Table is exceeded.",
        "description": "单VPC创建网关路由表Quota已达上限。"
      },
      {
        "errorCode": "MissingParam.vpcId",
        "errorMessage": "The parameter vpcId is mandatory.",
        "description": "参数缺失，vpcId是必选参数"
      },
      {
        "errorCode": "InvalidRegionId.NotFound",
        "errorMessage": "Specified value of RegionId is not supported.",
        "description": ""
      },
      {
        "errorCode": "InvalidParameter.Action",
        "errorMessage": "This vpc feature is not supported in this region",
        "description": ""
      }
    ],
    "404": [
      {
        "errorCode": "InvalidVpcId.NotFound",
        "errorMessage": "Specified VPC does not exist.",
        "description": ""
      }
    ]
  },
  "responseDemo": [
    {
      "type": "json",
      "example": "{\n  \"RequestId\": \"62172DD5-6BAC-45DF-8D44-E11ED28DCAC0\",\n  \"RouteTableId\": \"vtb-bp145q7glnuzdvzu2****\"\n}",
      "errorExample": ""
    },
    {
      "type": "xml",
      "example": "<CreateRouteTableResponse>\n    <RequestId>62172DD5-6BAC-45DF-8D44-E11ED28DCAC0</RequestId>\n    <RouteTableId>vtb-bp145q7glnuzdvzu2****</RouteTableId>\n</CreateRouteTableResponse>",
      "errorExample": ""
    }
  ]
}