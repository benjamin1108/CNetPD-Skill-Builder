        "description": ""
      }
    ]
  },
  "responseDemo": [
    {
      "type": "json",
      "example": "{\n  \"Spec\": \"Small.1\",\n  \"RequestId\": \"4EC47282-1B74-4534-BD0E-403F3EE64CAF\"\n}",
