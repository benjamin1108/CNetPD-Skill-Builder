        "type": "string",
        "required": false,
        "example": "test"
      }
    },
    {
      "name": "Description",
      "in": "query",
      "schema": {
        "description": "IPv6地址的描述信息。\n\n长度为0-256个字符，不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "test"
      }
    },
    {
      "name": "DryRun",
      "in": "query",
