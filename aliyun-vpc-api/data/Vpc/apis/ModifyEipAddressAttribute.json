  "api": "ModifyEipAddressAttribute",
  "group": "eip",
  "title": "修改EIP属性",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
