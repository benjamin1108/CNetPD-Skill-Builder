{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "GetNatIpCidrAttribute",
  "group": "misc",
  "title": "查看单个NAT IP地址段详细信息",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "get",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "要查询的 NAT IP 地址段所属 NAT 网关实例的地域 ID。\n\n您可以通过调用 DescribeRegions 接口获取地域 ID。",
        "type": "string",
        "required": true,
        "example": "eu-central-1"
      }
    },
    {
      "name": "NatIpCidr",
      "in": "query",
      "schema": {
        "description": "要查询的 NAT IP 地址段。",
        "type": "string",
        "required": true,
        "example": "192.168.0.0/24"
      }
    },
    {
      "name": "DryRun",
      "in": "query",
      "schema": {
        "description": "是否只预检此次请求，取值：\n\n- true：发送检查请求。检查项包括 AccessKey 是否有效、RAM 用户的授权情况和是否填写了必需参数。如果检查不通过，则返回对应错误。如果检查通过，会返回错误码DryRunOperation。\n\n- false（默认值）：发送正常请求，通过检查后返回2xx HTTP 状态码。",
        "type": "boolean",
        "required": false,
        "example": "false"
      }
    },
    {
      "name": "ClientToken",
      "in": "query",
      "schema": {
        "description": "客户端 Token，用于保证请求的幂等性。\n\n从您的客户端生成一个参数值，确保不同请求间该参数值唯一。ClientToken 只支持 ASCII 字符。\n\n> 若您未指定，则系统自动使用 API 请求的 RequestId 作为 ClientToken 标识。每次 API 请求的 RequestId 不一样。",
        "type": "string",
        "required": false,
        "example": "5A2CFF0E-5718-45B5-9D4D-70B3FF3898"
      }
    },
    {
      "name": "NatGatewayId",
      "in": "query",
      "schema": {
        "description": "要查询的 NAT IP 地址段所属的 VPC NAT 网关实例 ID。",
        "type": "string",
        "required": true,
        "example": "ngw-gw8v16wgvtq26vh59****"
      }
    },
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "要查询的 NAT IP 地址段所属 NAT 网关实例的地域 ID。\n\n您可以通过调用 DescribeRegions 接口获取地域 ID。",
        "type": "string",
        "required": true,
        "example": "eu-central-1"
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "type": "object",
        "properties": {
          "NatIpCidrId": {
            "description": "查询的 NAT IP 地址段的实例 ID。",
            "type": "string",
            "example": "vpcnatcidr-gw8lhqtvdn4qnea****"
          },
          "NatIpCidr": {
            "description": "查询的 NAT IP 地址段。",
            "type": "string",
            "example": "172.16.0.0/24"
          },
          "NatIpCidrName": {
            "description": "查询的 NAT IP 地址段名称。",
            "type": "string",
            "example": "default"
          },
          "NatIpCidrStatus": {
            "description": "查询的 NAT IP 地址段的状态。取值：\n\n- Available：可用状态。\n\n- Deleting：删除中。\n\n- Creating：创建中。",
            "type": "string",
            "example": "Available"
          },
          "RequestId": {
            "description": "请求 ID。",
            "type": "string",
            "example": "E9AD97A0-5338-43F8-8A80-5E274CCBA11B"
          },
          "NatGatewayId": {
            "description": "查询的 NAT IP 地址段所属的 VPC NAT 网关实例 ID。",
            "type": "string",
            "example": "ngw-gw8v16wgvtq26vh59****"
          },
          "NatIpCidrDescription": {
            "description": "查询的 NAT IP 地址段描述。",
            "type": "string",
            "example": "default"
          }
        },
        "description": ""
      }
    }
  },
  "errorCodes": {
    "404": [
      {
        "errorCode": "InvalidRegionId.NotFound",
        "errorMessage": "The specified RegionId does not exist in our records.",
        "description": ""
      }
    ]
  },
  "responseDemo": [
    {
      "errorExample": "",
      "example": "{\n  \"NatIpCidrId\": \"vpcnatcidr-gw8lhqtvdn4qnea****\",\n  \"NatIpCidr\": \"172.16.0.0/24\",\n  \"NatIpCidrName\": \"default\",\n  \"NatIpCidrStatus\": \"Available\",\n  \"RequestId\": \"E9AD97A0-5338-43F8-8A80-5E274CCBA11B\",\n  \"NatGatewayId\": \"ngw-gw8v16wgvtq26vh59****\",\n  \"NatIpCidrDescription\": \"default\"\n}",
      "type": "json"
    }
  ]
}