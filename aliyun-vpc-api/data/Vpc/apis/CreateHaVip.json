{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "CreateHaVip",
  "group": "havip",
  "title": "创建高可用虚拟IP（HaVip）",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "create",
  "description": "**CreateHaVip**接口属于异步接口，即系统会返回HaVip的ID，但该HaVip尚未创建完成，系统后台的创建任务仍在进行。您可以调用DescribeHaVips查询HaVip的创建状态：\n- 当HaVip处于**Creating**状态时，表示HaVip正在创建中。\n- 当HaVip处于**Available**状态时，表示HaVip创建完成。",
  "requestParamsDescription": "",
  "responseParamsDescription": "",
  "extraInfo": "",
  "parameters": [
    {
      "name": "Name",
      "in": "query",
      "schema": {
        "description": "HaVip的名称。\n\n名称长度为1～128个字符，不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "test"
      }
    },
    {
      "name": "ClientToken",
      "in": "query",
      "schema": {
        "description": "客户端Token，用于保证请求的幂等性。\n\n从您的客户端生成一个参数值，确保不同请求间该参数值唯一。ClientToken只支持ASCII字符。\n\n> 若您未指定，则系统自动使用API请求的**RequestId**作为**ClientToken**标识。每次API请求的**RequestId**不一样。",
        "type": "string",
        "required": false,
        "example": "0c593ea1-3bea-11e9-b96b-88e9fe637760"
      }
    },
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "HaVip所在的地域。您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-hangzhou"
      }
    },
    {
      "name": "VSwitchId",
      "in": "query",
      "schema": {
        "description": "HaVip所属的交换机ID。",
        "type": "string",
        "required": true,
        "example": "vsw-asdfjlnaue4g****"
      }
    },
    {
      "name": "IpAddress",
      "in": "query",
      "schema": {
        "description": "HaVip的IP地址。\n\n指定的IP地址必须为交换机网段中未被占用的IP地址。如果不指定，则从指定的交换机中随机分配一个未被占用的IP地址。",
        "type": "string",
        "required": false,
        "example": "192.XX.XX.10"
      }
    },
    {
      "name": "Description",
      "in": "query",
      "schema": {
        "description": "HaVip的描述信息。\n\n描述长度为1～255个字符，不能以`http://`或`https://`开头。",
        "type": "string",
        "required": false,
        "example": "This is my HaVip."
      }
    },
    {
      "name": "ResourceGroupId",
      "in": "query",
      "schema": {
        "description": "HaVip所属的资源组ID。",
        "type": "string",
        "required": false,
        "example": "rg-acfmxazb4ph6aiy****"
      }
    },
    {
      "name": "Tag",
      "in": "query",
      "style": "repeatList",
      "schema": {
        "description": "资源的标签。",
        "type": "array",
        "items": {
          "description": "标签。",
          "type": "object",
          "properties": {
            "Key": {
              "description": "资源的标签键。最多支持输入20个标签键。如需传入该值，则不能输入空字符串。\n\n一个标签键最多支持128个字符，不能以`aliyun`和`acs:`开头，不能包含`http://`或者`https://`。",
              "type": "string",
              "required": false,
              "example": "FinanceDept"
            },
            "Value": {
              "description": "资源的标签值。最多支持输入20个标签值。如需传入该值，可以输入空字符串。\n\n最多支持128个字符，不能以`aliyun`和`acs:`开头，不能包含`http://`或者`https://`。",
              "type": "string",
              "required": false,
              "example": "FinanceJoshua"
            }
          },
          "required": false
        },
        "required": false,
        "maxItems": 21
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "description": "返回信息。",
        "type": "object",
        "properties": {
          "RequestId": {
            "description": "请求ID。",
            "type": "string",
            "example": "C44F62BE-9CE7-4277-B117-69243F3988BF"
          },
          "IpAddress": {
            "description": "HaVip的IP地址。",
            "type": "string",
            "example": "192.XX.XX.10"
          },
          "HaVipId": {
            "description": "HaVip的ID。",
            "type": "string",
            "example": "havip-2zeo05qre24nhrqpy****"
          }
        }
      }
    }
  },
  "errorCodes": {
    "400": [
      {
        "errorCode": "InvalidDescription.Malformed",
        "errorMessage": "The specified Description  is wrongly formed.",
        "description": "入参Description无效"
      },
      {
        "errorCode": "InvalidIPAddress.OutOfRange",
        "errorMessage": "The specified IPAddress is out of VSwitch CIDR.",
        "description": ""
      },
      {
        "errorCode": "InvalidIPAddress.NotAvailable",
        "errorMessage": "The specified IPAddress is not available because it is a system reserved IPAddress.",
        "description": ""
      },
      {
        "errorCode": "InvalidIPAddress.AlreadyUsed",
        "errorMessage": "The specified IPAddress is already used by other resource.",
        "description": ""
      },
      {
        "errorCode": "InvalidIPAddress.Malformed",
        "errorMessage": "The specified IPAddress is not a valid or strict address.",
        "description": "传入的IP地址不合法。"
      },
      {
        "errorCode": "Abs.Vpc.InvalidName.Malformed",
        "errorMessage": "The specified Name is not valid.",
        "description": "传入的Name无效"
      },
      {
        "errorCode": "InvalidIPAddress.OutOfVswCIDR",
        "errorMessage": "The specified IPAddress is out of VSwitch CIDR.",
        "description": "指定的IP地址超出虚拟交换机（VSwitch）的CIDR段"
      },
      {
        "errorCode": "InvalidIPAddress.AlreadyInUse",
        "errorMessage": "The specified IPAddress is already used by other resource.",
        "description": "指定的IP地址已经被其他资源使用"
      },
      {
        "errorCode": "UnsupportedFeature.CloudBoxHaVip",
        "errorMessage": "The HAVIP feature is not supported in cloud box.",
        "description": "云盒不支持创建高可用vip。"
      },
      {
        "errorCode": "CountLimitExceed.HaVipInVpc",
        "errorMessage": "Specified Vpc exceeds the quota of max number of ha-vip count.",
        "description": ""
      },
      {
        "errorCode": "Forbidden.HaVip",
        "errorMessage": "No permissions to perform operations on HAVIPs. Please apply for privilege--vpc_privilege_allow_buy_havip_instance.",
        "description": "操作HaVip没有权限，请到配额中心申请权限。"
      },
      {
        "errorCode": "OperationDenied.InvalidIpReservedByVSwitch",
        "errorMessage": "The specified ip address is the reserved address of the switch.",
        "description": ""
      },
      {
        "errorCode": "InvalidRegionId.NotFound",
        "errorMessage": "Specified value of \"regionId\" is not supported.",
        "description": ""
      },
      {
        "errorCode": "IllegalParam.ResourceGroupId",
        "errorMessage": "Invalid ResourceGroupld value.",
        "description": "指定的资源组非法或不存在"
      },
      {
        "errorCode": "IncorrectStatus.VSwitch",
        "errorMessage": "The specified vSwitch status is invalid.",
        "description": "虚拟交换机状态异常。"
      }
    ],
    "403": [
      {
        "errorCode": "CountLimitExceed.HaVipInVpc",
        "errorMessage": "Specified Vpc exceeds the quota of max number of ha-vip count.",
        "description": ""
      },
      {
        "errorCode": "QuotaExceeded.HaVip",
        "errorMessage": "Living HaVip quota exceeded.",
        "description": ""
      }
    ],
    "404": [
      {
        "errorCode": "InvalidVSwitchId.NotFound",
        "errorMessage": "The specified VSwitch does not exist in the specified region.",
        "description": ""
      }
    ]
  },
  "responseDemo": [
    {
      "type": "json",
      "example": "{\n  \"RequestId\": \"C44F62BE-9CE7-4277-B117-69243F3988BF\",\n  \"IpAddress\": \"192.XX.XX.10\",\n  \"HaVipId\": \"havip-2zeo05qre24nhrqpy****\"\n}",
      "errorExample": ""
    },
    {
      "type": "xml",
      "example": "<CreateHaVipResponse>\n    <RequestId>C44F62BE-9CE7-4277-B117-69243F3988BF</RequestId>\n    <IpAddress>192.XX.XX.10</IpAddress>\n    <HaVipId>havip-2zeo05qre24nhrqpy****</HaVipId>\n</CreateHaVipResponse>",
      "errorExample": ""
    }
  ]
}