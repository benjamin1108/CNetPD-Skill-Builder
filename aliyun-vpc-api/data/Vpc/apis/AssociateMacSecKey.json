{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "AssociateMacSecKey",
  "group": "misc",
  "title": "关联MacSec密钥",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "update",
  "description": "使用该功能需要满足以下条件：\n\n- 物理专线所在的设备支持MacSec特性\n\n- 物理专线需要付款完成\n\n- 只支持在独享物理专线配置\n\n其他使用说明：\n\n- 最多只支持配置3组Ckn和Cak\n\n- 关联当前处于Disassociated状态的密钥，会取消关联之前生效的密钥\n\n- 关联当前处于AssociatedFailed状态的密钥，会触发设备进行重新协商会话",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "物理专线所在的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-hangzhou"
      }
    },
    {
      "name": "PhysicalConnectionId",
      "in": "query",
      "schema": {
        "description": "物理专线 ID。",
        "type": "string",
        "required": true,
        "example": "pc-bp1hp0wr072f6****"
      }
    },
    {
      "name": "CipherSuite",
      "in": "query",
      "schema": {
        "description": "加密算法类型，取值范围：\n\n- GCM-AES-128\n\n- GCM-AES-XPN-128\n\n- GCM-AES-256\n\n- GCM-AES-XPN-256",
        "type": "string",
        "required": true,
        "example": "GCM-AES-128"
      }
    },
    {
      "name": "Ckn",
      "in": "query",
      "schema": {
        "description": "密钥名称，只支持十六进制字符，小写会自动转换为大写，当加密算法类型是GCM-AES-128或者GCM-AES-XPN-128时，长度要求为32个十六进制字符，当加密算法类型是GCM-AES-256或者GCM-AES-XPN-256时，长度要求为64个十六进制字符",
        "type": "string",
        "required": true,
        "example": "0123456789ABCDEF0123456789ABCDEF"
      }
    },
    {
      "name": "Cak",
      "in": "query",
      "schema": {
        "description": "密钥密码，只支持十六进制字符，小写会自动转换为大写，当加密算法类型是GCM-AES-128或者GCM-AES-XPN-128时，长度要求为32个十六进制字符，当加密算法类型是GCM-AES-256或者GCM-AES-XPN-256时，长度要求为64个十六进制字符",
        "type": "string",
        "required": true,
        "example": "0123456789ABCDEF0123456789ABCDEF"
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "type": "object",
        "properties": {
          "RequestId": {
            "description": "请求ID。",
            "type": "string",
            "example": "D32B3C26-6C6C-4988-93E9-D2A6444CE6AE"
          }
        },
        "description": ""
      }
    }
  },
  "errorCodes": {
    "400": [
      {
        "errorCode": "IllegalParam.%s",
        "errorMessage": "The param of %s is illegal.",
        "description": "指定的参数非法"
      },
      {
        "errorCode": "ResourceNotFound.PhysicalConnectionId",
        "errorMessage": "The specified resource of [%s] is not found.",
        "description": "PhysicalConnection不存在。"
      },
      {
        "errorCode": "IncorrectStatus.PhysicalConnection",
        "errorMessage": "The status of %s [%s] is incorrect.",
        "description": "物理专线的状态不支持此操作。"
      },
      {
        "errorCode": "UnsupportedFeature.Macsec",
        "errorMessage": "The feature of Macsec is not supported.",
        "description": "当前物理专线不支持MACSec特性。"
      },
      {
        "errorCode": "IncorrectStatus.PconnMacsec",
        "errorMessage": "The status of %s [%s] is incorrect.",
        "description": "不允许进行操作因为有MACSec秘钥处于非稳态。"
      },
      {
        "errorCode": "QuotaExceeded.PconnMacsec",
        "errorMessage": "The quota of PconnMacsec is exceeded, usage 3/3.",
        "description": "一条物理专线最多支持绑定3组MACSec秘钥。"
      },
      {
        "errorCode": "UnsupportedFeature.Macsec.CipherSuite",
        "errorMessage": "The feature of Macsec.CipherSuite is not supported.",
        "description": "当前物理专线支持MACSec，但是不支持选择的加密算法。"
      }
    ]
  },
  "responseDemo": [
    {
      "errorExample": "",
      "example": "{\n  \"RequestId\": \"D32B3C26-6C6C-4988-93E9-D2A6444CE6AE\"\n}",
      "type": "json"
    }
  ]
}