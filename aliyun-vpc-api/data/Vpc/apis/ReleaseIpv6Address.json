        "type": "boolean",
        "required": false,
        "example": "false"
      }
    },
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-hangzhou"
      }
    }
