{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "DeleteFailoverTestJob",
  "group": "fault-simulation",
  "title": "删除高速通道故障演练任务",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
