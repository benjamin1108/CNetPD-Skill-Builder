  "operationType": "update",
  "requestParamsDescription": "",
  "responseParamsDescription": "",
  "extraInfo": "",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "访问控制策略组的地域。",
        "type": "string",
        "required": true,
        "example": "cn-hangzhou"
      }
    },
    {
      "name": "AclId",
      "in": "query",
      "schema": {
        "description": "IP条目所在的访问控制策略组ID。",
        "type": "string",
        "required": true,
        "example": "ipv6transacl-bp1b4z3tleyhq1s50****"
