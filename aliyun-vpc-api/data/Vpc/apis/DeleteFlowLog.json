{
  "_layer": "L2",
  "_version": "2.0.0",
  "product": "Vpc",
  "api": "DeleteFlowLog",
  "group": "flow-log",
  "title": "删除流日志",
  "methods": [
    "post",
    "get"
  ],
  "schemes": [
    "http",
    "https"
  ],
  "security": [
    {
      "AK": []
    }
  ],
  "operationType": "delete",
  "description": "- **DeleteFlowLog**接口属于异步接口，即系统返回一个实例ID，但流日志尚未删除成功，系统后台的删除任务仍在进行。您可以调用DescribeFlowLogs查询流日志的删除状态：\n    - 当流日志处于**Deleting**状态时，表示流日志正在删除中。\n    - 当查询不到指定的流日志时，表示流日志删除成功。\n- **DeleteFlowLog**接口不支持并发删除同一个流日志。",
  "requestParamsDescription": "",
  "responseParamsDescription": "",
  "extraInfo": "",
  "parameters": [
    {
      "name": "RegionId",
      "in": "query",
      "schema": {
        "description": "流日志所属的地域ID。\n\n您可以通过调用DescribeRegions接口获取地域ID。",
        "type": "string",
        "required": true,
        "example": "cn-qingdao"
      }
    },
    {
      "name": "FlowLogId",
      "in": "query",
      "schema": {
        "description": "流日志ID。",
        "type": "string",
        "required": true,
        "example": "fl-m5e8vhz2t21sel1nq****"
      }
    }
  ],
  "responses": {
    "200": {
      "schema": {
        "type": "object",
        "properties": {
          "Success": {
            "description": "是否调用成功。取值：\n\n- **true**：调用成功。\n- **false**：调用失败。",
            "type": "string",
            "example": "true"
          },
          "RequestId": {
            "description": "请求ID。",
            "type": "string",
            "example": "F7DDDC17-FA06-4AC2-8F35-59D2470FCFC1"
          }
        }
      }
    }
  },
